#!/usr/bin/env bash
# Kmpl: acme glue for u/complete. Triggers completion and inserts at cursor.
set -euo pipefail

cmd=${0##*/}
die() { printf '%s: %s\n' "$cmd" "$*" >&2; exit 1; }

[ -z "${winid:-}" ] || [ "$winid" = "0" ] && die "must be run from an acme window"

# Get filename for language context
filename=$(9p read acme/$winid/ctl | awk 'NR==1{print $NF}')

# Sync addr to current dot, read rune offsets
echo "addr=dot" | 9p write acme/$winid/ctl
addr=$(9p read acme/$winid/addr)
q0=$(printf '%s' "$addr" | cut -d, -f1 | tr -d '#[:space:]')
q1=$(printf '%s' "$addr" | cut -d, -f2 | tr -d '#[:space:]')

# Read prefix (before dot) and suffix (from dot onward)
printf '#0,#%s' "$q0" | 9p write acme/$winid/addr
prefix=$(9p read acme/$winid/data)

printf '#%s,$' "$q1" | 9p write acme/$winid/addr
suffix=$(9p read acme/$winid/data)

# Compute cursor line/col for LSP calls
line=$(printf '%s' "$prefix" | wc -l)
[ "$line" -eq 0 ] && line=1
col=$(printf '%s' "$prefix" | tail -1 | wc -m)

# Gather LSP context in parallel
tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT

python3 $OLLIE/t/lsp_completion "$filename" "$line" "$col" > "$tmpdir/completions" 2>/dev/null &
python3 $OLLIE/t/lsp_symbols "$filename" > "$tmpdir/symbols" 2>/dev/null &
python3 $OLLIE/t/lsp_hover "$filename" "$line" "$col" > "$tmpdir/hover" 2>/dev/null &
wait

context=""
[ -s "$tmpdir/completions" ] && context="${context}<completions>
$(cat "$tmpdir/completions")
</completions>
"
[ -s "$tmpdir/symbols" ] && context="${context}<symbols>
$(cat "$tmpdir/symbols")
</symbols>
"
[ -s "$tmpdir/hover" ] && context="${context}<hover>
$(cat "$tmpdir/hover")
</hover>
"

# Fetch completion
result=$(printf '%s' "$prefix" | $OLLIE/u/complete -file "$filename" -suffix "$suffix" -context "$context" "$@")

# Insert at cursor
echo "addr=dot" | 9p write acme/$winid/ctl
#printf '%s' "$result" | 9p write acme/$winid/data
printf '%s' "$result"
